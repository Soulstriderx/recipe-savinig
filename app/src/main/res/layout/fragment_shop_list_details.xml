<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"

    tools:context=".ui.detailsshoplist.ShopListDetailsFragment">

    <RelativeLayout
        android:id="@+id/llHeaderDetails"
        android:layout_width="match_parent"
        android:layout_height="@dimen/space_xxxxxl"
        android:layout_alignParentTop="true"
        android:background="@color/color_secondary"
        android:orientation="horizontal"
        android:padding="@dimen/space_l" >

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <TextView
            android:id="@+id/tvShopListName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Shop List Name"
            android:textColor="@color/white"
            android:textSize="@dimen/text_xxxxl"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_edit" />

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/llAddIngredient"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/box_bg"
        android:orientation="vertical"
        android:paddingVertical="@dimen/space_xs"
        android:elevation="@dimen/space_xs"
        android:layout_below="@id/llHeaderDetails">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/add_ingredient"
            android:textSize="@dimen/text_l"
            android:textStyle="bold"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/space_s"
            android:weightSum="4">

            <EditText
                android:id="@+id/etIngredient"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:layout_marginHorizontal="@dimen/space_xxs"
                android:hint="@string/ingredient"
                android:background="@drawable/edit_text_bg_2" />

            <EditText
                android:id="@+id/etAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/amount"
                android:layout_marginHorizontal="@dimen/space_xxs"
                android:background="@drawable/edit_text_bg_2" />

            <EditText
                android:id="@+id/etUnit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/unit"
                android:layout_marginHorizontal="@dimen/space_xxs"
                android:background="@drawable/edit_text_bg_2" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/store"
            android:textSize="@dimen/text_l"
            android:textStyle="bold"
            android:gravity="center" />

        <Spinner
            android:id="@+id/spStoreName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/space_xs"
            android:background="@drawable/edit_text_bg_2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="@dimen/space_xs"
            android:layout_marginTop="@dimen/space_l"
            android:weightSum="10">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/mbAdd"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="9"
                android:backgroundTint="@color/color_primary"
                android:paddingVertical="@dimen/space_s"
                android:text="@string/add_recipes"
                android:textSize="@dimen/text_xl" />

            <ImageView
                android:id="@+id/ivDelete"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@drawable/ic_trash"
                android:layout_marginStart="@dimen/space_xs"/>

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvStoreName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/llHeaderDetails"
        android:gravity="center"
        android:padding="@dimen/space_xs"
        android:text="@string/store"
        android:textSize="@dimen/text_xxxl"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvShopListDetails"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/llAddIngredient" />

</RelativeLayout>