<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/llAddInstruction"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="@dimen/space_xs">

    <TextView
        android:id="@+id/tvAddInstructionStep"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textSize="@dimen/text_xl"
        android:layout_marginBottom="@dimen/space_xs"
        android:layout_marginEnd="@dimen/space_xs"/>

    <EditText
        android:id="@+id/etInstruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/instruction"
        android:background="@drawable/edit_text_bg" />

</LinearLayout>