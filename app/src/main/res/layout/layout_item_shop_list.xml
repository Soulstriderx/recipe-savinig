<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/text_l"
    android:layout_marginHorizontal="@dimen/space_l"
    android:layout_marginTop="@dimen/space_l"
    android:elevation="@dimen/space_xs" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3">

        <TextView
            android:id="@+id/tvIngredient"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Ingredient"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"/>

       <LinearLayout
           android:layout_width="0dp"
           android:layout_height="wrap_content"
           android:orientation="horizontal"
           android:gravity="end"
           android:layout_weight="1" >

           <TextView
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:text="RM"
               android:textSize="@dimen/text_l" />

           <TextView
               android:id="@+id/tvTotalPrice"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:text="150"
               android:textSize="@dimen/text_l"/>

       </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/space_xxxxs"
        android:layout_marginBottom="@dimen/space_xxxs">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/space_xxxs"
            android:text="Items: "
            android:textSize="@dimen/text_l" />

        <TextView
            android:id="@+id/tvTotalItems"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5"
            android:textSize="@dimen/text_l" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal" >

        <TextView
            android:id="@+id/tvStore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wallmart"
            android:textSize="@dimen/text_l" />
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="25/5/2005"
            android:textColor="@color/t_gray_text"
            android:textSize="@dimen/text_l"/>

    </LinearLayout>

</LinearLayout>